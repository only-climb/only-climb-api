# Copy this file to .env for local development.
# docker-compose reads .env automatically; Spring Boot does NOT — for the
# app, export these as environment variables or use your IDE run config.

# Postgres (used by docker-compose)
POSTGRES_DB=onlyclimb
POSTGRES_USER=onlyclimb
POSTGRES_PASSWORD=onlyclimb
POSTGRES_PORT=5432

# Spring Boot datasource (must match the values above)
DB_URL=jdbc:postgresql://localhost:5432/onlyclimb
DB_USERNAME=onlyclimb
DB_PASSWORD=onlyclimb
